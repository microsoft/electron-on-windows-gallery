{
  "name": "electron-gallery",
  "version": "1.0.0",
  "description": "An Electron app which shows sample functionality of the Electron platform.",
  "main": "main.js",
  "scripts": {
    "start": "electron-forge start",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "electron-builder --dir",
    "create-msix": "npm run build & winapp package ./dist/win-arm64-unpacked/ --output ./dist/ --cert ./devcert.pfx",
    "build-myAddon": "node-gyp clean configure build --directory=myAddon --arch=arm64",
    "build-all": "npm run build-myAddon",
    "setup-debug": "npx winapp node add-electron-debug-identity",
    "package": "electron-forge package",
    "make": "electron-forge make"
    },
  "build": {
    "files": [
      "**/*",
      "!.winapp/**"
    ]
  },
  "repository": "https://github.com/microsoft/electron-gallery",
  "author": "Microsoft",
  "license": "MIT",
  "private": false,
  "devDependencies": {
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-deb": "^7.10.2",
    "@electron-forge/maker-rpm": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@electron-forge/maker-zip": "^7.10.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.10.2",
    "@electron-forge/plugin-fuses": "^7.10.2",
    "@electron/fuses": "^1.8.0",
    "@types/node": "^24.8.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "electron": "^37.2.5",
    "nan": "^2.23.0",
    "node-addon-api": "^8.5.0",
    "node-gyp": "^11.4.2",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.72.2",
    "@fluentui/react-icons": "^2.0.312",
    "@fluentui/web-components": "^2.6.1",
    "@microsoft/winapp-windows-ai": "../winapp-windows-ai/artifacts/microsoft-winapp-windows-ai-0.1.3.tgz",
    "@microsoft/winappcli": "^0.1.7",
    "@vitejs/plugin-react": "^5.0.4",
    "electron-squirrel-startup": "^1.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "^7.1.10"
  },
  "//": {
    "overrides": {
      "app-builder-lib": {
        "@electron/rebuild": "4.0.1"
      }
    }
  }
}
