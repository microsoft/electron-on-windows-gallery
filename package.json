{
  "name": "electron-gallery",
  "version": "1.0.0",
  "description": "An Electron app which shows sample functionality of the Electron platform.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "electron-builder --dir",
    "create-msix": "npm run build & winapp package ./dist/win-arm64-unpacked/ --output ./dist/ --cert ./devcert.pfx",
    "build-myAddon": "node-gyp clean configure build --directory=myAddon --arch=arm64",
    "build-PhiSilicaAddon": "node-gyp clean configure build --directory=PhiSilicaAddon --arch=arm64",
    "build-WindowsAIAddon": "node-gyp clean configure build --directory=WindowsAIAddon --arch=arm64",
    "build-all": "npm run build-myAddon && npm run build-PhiSilicaAddon && npm run build-WindowsAIAddon",
    "setup-debug": "npx winapp node add-electron-debug-identity"
  },
  "build": {
    "files": [
      "**/*",
      "!.winapp/**"
    ]
  },
  "repository": "https://github.com/microsoft/electron-gallery",
  "author": "Microsoft",
  "license": "MIT",
  "private": false,
  "devDependencies": {
    "@types/node": "^24.8.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "electron": "^37.2.5",
    "electron-builder": "^26.0.12",
    "nan": "^2.23.0",
    "node-addon-api": "^8.5.0",
    "node-gyp": "^11.4.2",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.72.2",
    "@fluentui/react-icons": "^2.0.312",
    "@fluentui/web-components": "^2.6.1",
    "@vitejs/plugin-react": "^5.0.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "^7.1.10",
    "electron-windows-ai-addon": "file:../electron-windows-ai-addon/artifacts/electron-windows-ai-addon-0.1.0-prerelease.2.tgz",
    "@microsoft/winappcli": "..\\winappcli\\artifacts\\microsoft-winappcli-0.1.1.tgz"
  },
  "//": {
    "overrides": {
      "app-builder-lib": {
        "@electron/rebuild": "4.0.1"
      }
    }
  }
}
