{
  "name": "electron-on-windows-gallery",
  "version": "0.1.0",
  "description": "An Electron app which shows sample functionality of the Electron platform.",
  "main": "main.js",
  "scripts": {
    "start": "electron-forge start",
    "create-msix-arm64": "winapp pack ./out/electron-on-windows-gallery-win32-arm64/ --output ./dist/arm64 --manifest ./appxmanifest.xml --name electron-on-windows-gallery-arm64",
    "create-msix-x64": "winapp pack ./out/electron-on-windows-gallery-win32-x64/ --output ./dist/x64 --manifest ./appxmanifest.xml --name electron-on-windows-gallery-x64",
    "create-msix-all": "npm run create-msix-arm64 && npm run create-msix-x64",
    "build-myAddon-arm64": "cd myAddon && node-gyp rebuild --arch=arm64 --target=37.2.5 --dist-url=https://electronjs.org/headers && if not exist bin\\arm64 mkdir bin\\arm64 && copy /Y build\\Release\\myAddon.node bin\\arm64\\myAddon.node",
    "build-myAddon-x64": "cd myAddon && node-gyp rebuild --arch=x64 --target=37.2.5 --dist-url=https://electronjs.org/headers && if not exist bin\\x64 mkdir bin\\x64 && copy /Y build\\Release\\myAddon.node bin\\x64\\myAddon.node",
    "build-all": "npm run build-myAddon-arm64 && npm run build-myAddon-x64",
    "setup-debug": "npx winapp node add-electron-debug-identity",
    "package-arm64": "npm run build-myAddon-arm64 && electron-forge package --arch=arm64",
    "package-x64": "npm run build-myAddon-x64 && electron-forge package --arch=x64",
    "package-all": "npm run build-all && npm run package-arm64 && npm run package-x64"
  },
  "build": {
    "files": [
      "**/*",
      "!.winapp/**"
    ]
  },
  "repository": "https://github.com/microsoft/electron-on-windows-gallery",
  "author": "Microsoft",
  "license": "MIT",
  "private": false,
  "devDependencies": {
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-deb": "^7.10.2",
    "@electron-forge/maker-rpm": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@electron-forge/maker-zip": "^7.10.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.10.2",
    "@electron-forge/plugin-fuses": "^7.10.2",
    "@electron/fuses": "^1.8.0",
    "@microsoft/winappcli": "^0.1.8",
    "@types/node": "^24.8.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^37.2.5",
    "nan": "^2.23.0",
    "node-addon-api": "^8.5.0",
    "node-gyp": "^11.4.2",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.10"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.72.2",
    "@fluentui/react-icons": "^2.0.312",
    "@fluentui/web-components": "^2.6.1",
    "@modelcontextprotocol/sdk": "^1.25.0",
    "dotenv": "^17.2.3",
    "dynwinrt-js": "^0.1.2",
    "electron-squirrel-startup": "^1.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "winrt-meta": "^0.1.2"
  },
  "//": {
    "overrides": {
      "app-builder-lib": {
        "@electron/rebuild": "4.0.1"
      }
    }
  }
}
