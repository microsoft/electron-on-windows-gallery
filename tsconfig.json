{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node"],
    "allowJs": true,
    "checkJs": false,
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": [
    "features-ts/**/*.ts"
  ]
}
